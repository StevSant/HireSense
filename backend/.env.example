# === Core ===
APP_NAME=HireSense
DEBUG=false
CORS_ORIGINS=http://localhost:4200
# Explicit CORS allow-lists (no wildcards; allow_credentials is on).
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_ALLOW_HEADERS=Authorization,Content-Type

# === Rate limiting (expensive endpoints) ===
# In-process sliding-window limiter, keyed by client IP, applied to the
# LLM/network-heavy endpoints. Disable for load tests.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
# Seconds shutdown waits for in-flight domain-event handlers before cancelling.
EVENT_BUS_DRAIN_TIMEOUT_SECONDS=5
# Bounds for the in-process embedding caches (LRU eviction).
SEMANTIC_JOB_CACHE_SIZE=2000
SEMANTIC_PROFILE_CACHE_SIZE=8

# === Auth ===
AUTH_USERNAME=admin
# The two sample values below are REJECTED at startup — replace both before
# first run. Generate strong values with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_PASSWORD=changeme
JWT_SECRET_KEY=change-this-to-a-random-secret
# Role embedded in issued tokens. Single-user instance is admin by default;
# set to a non-admin value to exercise the admin-only route gate.
AUTH_ROLE=admin

# === Database ===
DATABASE_URL=postgresql+asyncpg://hiresense:hiresense@localhost:5432/hiresense
# Connection-pool sizing for the shared sync engine (ignored for SQLite).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE_SECONDS=3600

# === LLM ===
LLM_PROVIDER=anthropic
# Options: anthropic | openai | groq | ollama
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-6
# Fernet key used to encrypt LLM API keys at rest in the llm_settings table.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, the admin /admin/llm-settings DB row falls back to the .env LLM_API_KEY
# and saving new keys via the API will fail with a clear 500 error.
LLM_SETTINGS_ENCRYPTION_KEY=
EMBEDDING_MODEL=all-mpnet-base-v2
# Options: all-mpnet-base-v2 | all-MiniLM-L6-v2 | any sentence-transformers model
EMBEDDING_DEVICE=cpu
# Options: cpu | cuda
# Embedding vector dimension — must match EMBEDDING_MODEL (all-mpnet-base-v2 = 768,
# all-MiniLM-L6-v2 = 384). Sizes the pgvector column + ANN index.
EMBEDDING_DIM=768
# Skip the HuggingFace Hub revision/metadata round-trip when the model is
# already cached locally (~/.cache/huggingface/hub). Removes the
# "unauthenticated requests to the HF Hub" warning and shaves a few hundred
# ms off every process start. Unset (or =0) to allow upstream model updates.
HF_HUB_OFFLINE=1

# === Vector Store ===
VECTOR_STORE_PROVIDER=pgvector
# Options: pgvector | chroma

# === Job Ingestion ===
INGESTION_SCHEDULE=0 */6 * * *
INGESTION_COOLDOWN_SECONDS=300
# Days to retain ingested jobs before HARD-deleting them (GC backstop; runs at
# the start of each fetch and portal scan). Closure detection is the primary
# lifecycle signal now, so this just bounds table growth. Set to 0 to disable.
INGESTION_JOB_RETENTION_DAYS=90
ENABLED_JOB_SOURCES=remotive,remoteok,jobicy,himalayas,hn_hiring,weworkremotely,getonboard,linkedin,arbeitnow,themuse
# Options: remotive,remoteok,jobicy,himalayas,hn_hiring,weworkremotely,getonboard,linkedin,arbeitnow,themuse,adzuna,csv,json
# Note: `linkedin` is a fragile guest-endpoint HTML scraper (ToS-risky, breaks
# on markup changes, rate-limits hard) — kept on by default for on-site
# coverage; drop it here if it misbehaves. `adzuna` also requires
# ADZUNA_APP_ID/ADZUNA_APP_KEY below.

# --- Job closure / revalidation ---
# Consecutive snapshot fetches a job may be missing before it's marked closed.
JOB_CLOSURE_MISS_THRESHOLD=2
# URL-probe revalidation sweep cadence + cost controls (feed/search sources).
JOB_REVALIDATION_INTERVAL_HOURS=24
JOB_REVALIDATION_BATCH=100
JOB_REVALIDATION_CONCURRENCY=2
JOB_REVALIDATION_DELAY=1.0
# Comma-separated, lowercased phrases that mark a 200-OK page as actually closed.
JOB_CLOSED_MARKERS=no longer accepting applications,position has been filled,this job is closed,this position is no longer available,ya no está disponible,esta oferta ya no está disponible

# === Outbound HTTP (shared client retry/backoff) ===
# Retry/backoff for the shared HTTP client wrapping every ingestion source
# adapter. Transient transport errors (timeout, connection reset) and the
# retryable status codes below are retried with exponential backoff
# (delay = HTTP_RETRY_BASE_DELAY * 2**attempt). Set HTTP_MAX_RETRIES=0 to disable.
HTTP_MAX_RETRIES=3
# Base delay (seconds) for the first retry; doubles each subsequent attempt.
HTTP_RETRY_BASE_DELAY=0.5
# Comma-separated HTTP status codes that trigger a retry.
HTTP_RETRY_STATUS_CODES=429,500,502,503,504

# === Job Source URLs ===
# Remotive remote-jobs API base URL.
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs
# RemoteOK public API base URL.
REMOTEOK_API_URL=https://remoteok.com/api
JOBICY_API_URL=https://jobicy.com/api/v2/remote-jobs
HIMALAYAS_API_URL=https://himalayas.app/jobs/api
HN_ALGOLIA_API_URL=https://hn.algolia.com/api/v1
WEWORKREMOTELY_RSS_URL=https://weworkremotely.com/remote-jobs.rss
GETONBOARD_API_URL=https://www.getonbrd.com/api/v0
# Comma-separated category IDs to ingest from Get on Board. Leave blank to
# fetch /search/jobs (all categories, no filter). Available IDs:
# programming, mobile-developer, design-ux, machine-learning-ai,
# sysadmin-devops-qa, customer-support, innovation-agile, operations-management,
# sales, technical-support, cybersecurity, digital-marketing,
# data-science-analytics, advertising-media, hr, education-coaching,
# hardware-electronics, other
GETONBOARD_CATEGORIES=programming,mobile-developer,design-ux,machine-learning-ai,sysadmin-devops-qa,data-science-analytics,cybersecurity,hardware-electronics
LINKEDIN_JOBS_URL=https://www.linkedin.com/jobs-guest/jobs/api
# LinkedIn per-job detail fetch tuning (guest endpoint rate-limits aggressively).
# Higher concurrency / lower delay means faster ingestion but more 429s.
LINKEDIN_DETAIL_CONCURRENCY=1
LINKEDIN_DETAIL_DELAY=1.0
# Arbeitnow free Job Board API (Europe + remote, no auth).
ARBEITNOW_API_URL=https://www.arbeitnow.com/api/job-board-api
# The Muse public Jobs API. Comma-separated categories narrow the broad board
# to dev-relevant roles. THEMUSE_API_KEY is optional (raises the rate limit).
THEMUSE_API_URL=https://www.themuse.com/api/public/jobs
THEMUSE_CATEGORIES=Software Engineering,Data Science,Design and UX,Product Management,IT
THEMUSE_API_KEY=
# Adzuna aggregator (global on-site/hybrid + salary). Get a free app_id/app_key
# at https://developer.adzuna.com. Adzuna is NOT in ENABLED_JOB_SOURCES by
# default — add `adzuna` there AND set both keys below to activate it.
ADZUNA_API_URL=https://api.adzuna.com/v1/api/jobs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Comma-separated ISO country codes to search (LATAM-leaning default).
ADZUNA_COUNTRIES=mx,br,ar
ADZUNA_QUERY=software developer

# === Portal Scanning ===
PORTALS_CONFIG_PATH=ingestion/config/portals.yml
PORTAL_SCAN_TIMEOUT=30
GREENHOUSE_API_URL=https://boards-api.greenhouse.io/v1/boards
LEVER_API_URL=https://api.lever.co/v0/postings
ASHBY_API_URL=https://api.ashbyhq.com/posting-api/job-board
# Workable public widget API ({base}/{subdomain}); board_id = account subdomain.
WORKABLE_API_URL=https://apply.workable.com/api/v1/widget/accounts
# SmartRecruiters public Posting API ({base}/{companyId}/postings).
SMARTRECRUITERS_API_URL=https://api.smartrecruiters.com/v1/companies
# Recruitee public Offers API. {company} is replaced with the portal board_id
# (the company subdomain) at fetch time.
RECRUITEE_API_URL=https://{company}.recruitee.com/api

# === LaTeX ===
LATEX_COMPILER=xelatex
# xelatex subprocess timeout per compile pass (seconds)
LATEX_TIMEOUT_SECONDS=60.0

# Hide ingestion-list jobs below this match score (0.0–1.0). Default 0.0
# shows everything; the match column + sort=match_desc are the triage path.
# Clients can override per request with ?min_score=0.25 etc.
INGESTION_MIN_MATCH_SCORE=0.0
# Cold-start ranking fairness: on a full rescore, LLM quick-score the top-N
# heuristic jobs of EVERY source (besides the visible page) so strong jobs
# from heuristic-underrated sources (e.g. getonboard) reach page 1 of the
# all-sources view. Cached per profile; 0 disables.
INGESTION_SOURCE_CHAMPIONS_PER_SOURCE=3
# Hard cap on ?page_size for job listings (values above are clamped).
INGESTION_MAX_PAGE_SIZE=100
# Directory CSV-import file_path filters are confined to (path-traversal guard).
CSV_IMPORT_DIR=./csv_imports
# Hide ingestion-list jobs whose posted date is older than this many days
# (stale / re-surfaced postings, e.g. WeWorkRemotely keeps the original RSS
# pubDate). Jobs with no posted date are never hidden. 0 disables; 365 hides
# anything older than a year. Override per request with ?max_age_days=.
INGESTION_MAX_JOB_AGE_DAYS=365
# Options: xelatex | docker_xelatex
CV_DIRECTORY=./cvs

# === Language ===
SUPPORTED_LANGUAGES=en,es
DEFAULT_LANGUAGE=en

# === Matching Weights (must sum to 100) ===
WEIGHT_SEMANTIC=15
WEIGHT_SKILL_MATCH=20
WEIGHT_EXPERIENCE=10
WEIGHT_LANGUAGE=5
WEIGHT_SENIORITY=10
WEIGHT_COMPENSATION=10
WEIGHT_GROWTH=5
WEIGHT_CULTURE=5
WEIGHT_APPLICATION=10
WEIGHT_INTERVIEW=10

# === Match Scoring (LLM model routing) ===
# Default models for the two match-scoring features. Both can be overridden
# per-feature in the admin LLM Settings UI (keys: match_quick_scorer,
# match_deep_analyzer). The quick scorer runs on the job list (cheap/fast);
# the deep analyzer runs on-demand in the detail panel (advanced).
MATCH_QUICK_MODEL=claude-haiku-4-5
# Options: claude-haiku-4-5 | gpt-4o-mini | llama-3.1-8b-instant | (any cheap model)
MATCH_DEEP_MODEL=claude-sonnet-4-6
# Options: claude-sonnet-4-6 | claude-opus-4-7 | gpt-4o | (any strong model)
# Jobs scored per quick-scorer LLM call (the visible page is scored in one
# batched request). Keep aligned with the listing page size.
MATCH_QUICK_BATCH_SIZE=20
# Per-job description truncation (chars) inside the batched quick prompt.
MATCH_QUICK_JOB_CHAR_LIMIT=1500
# Per-job description truncation (chars) for the deeper single-job analysis.
MATCH_DEEP_JOB_CHAR_LIMIT=6000

# === Batch Processing ===
BATCH_CONCURRENCY=3

# --- Preference learning loop ---
# Master switch for taste-vector re-ranking (true/false).
PREFERENCE_ENABLED=true
# Blend coefficients: taste = normalize(alpha*baseline + beta*positives - gamma*negatives)
PREFERENCE_ALPHA=1.0
PREFERENCE_BETA=0.75
PREFERENCE_GAMMA=0.5
# Recency decay time constant in days.
PREFERENCE_DECAY_TAU_DAYS=90.0
# Per-kind signal magnitudes.
PREFERENCE_WEIGHT_THUMBS_UP=1.0
PREFERENCE_WEIGHT_MORE_LIKE_THIS=1.0
PREFERENCE_WEIGHT_THUMBS_DOWN=1.0
PREFERENCE_WEIGHT_NOT_INTERESTED=1.5
# Implicit (Phase 2) per-kind magnitudes (tracking outcomes feed the taste vector).
PREFERENCE_WEIGHT_APPLIED=1.0
PREFERENCE_WEIGHT_INTERVIEWING=1.5
PREFERENCE_WEIGHT_OFFERED=2.5
PREFERENCE_WEIGHT_ACCEPTED=3.0
PREFERENCE_WEIGHT_REJECTED=1.5
# Phase 2: enable the LLM-phrased preference drift summary (true/false).
PREFERENCE_EXPLANATION_ENABLED=true
# Phase 2 dimension-weight nudging (preference -> matching composite scoring).
# Minimum outcome-bearing signals before any nudge applies (cold-start gate);
# below this, all overrides are zero and composite scoring is unchanged.
PREFERENCE_NUDGE_MIN_OUTCOMES=5
# Hard absolute clamp on the per-dimension integer weight delta.
PREFERENCE_NUDGE_CLAMP=3
# Maps a dimension's [-1, 1] outcome correlation to an integer delta
# (delta = round(correlation * scale)) before clamping.
PREFERENCE_NUDGE_SCALE=5.0

# --- Analytics dashboard ---
ANALYTICS_CACHE_TTL_SECONDS=300
ANALYTICS_TARGET_SALARY_TOP_K=50
ANALYTICS_TARGET_SALARY_MIN_SAMPLE=5
# Search-focus: a profile-matched job counts as "fresh" if posted within N days.
ANALYTICS_FOCUS_FRESH_DAYS=14
# Sampling cap for the full-corpus aggregation scans (top-skills, skill-gap,
# posting trend, salary distribution). Each scan reads at most this many open
# postings into memory, so the aggregates are computed over a SAMPLE of up to
# this size rather than the entire corpus — keeps memory bounded as the corpus
# grows. Raise for more exact figures at the cost of memory; numbers are only
# affected once the open-posting count exceeds this value.
ANALYTICS_CORPUS_SAMPLE_CAP=5000

# --- Admin LLM usage dashboard ---
# Default cap on rows returned by the "recent calls" listing (newest-first)
# when no explicit limit is requested. Bounds the SELECT over the usage log.
# The /usage/calls endpoint clamps its own ?limit= per request (1..500); this
# is the server-side default applied when none is passed.
ADMIN_USAGE_RECENT_LIMIT=100

# --- Proactive Auto-Hunt ---
AUTOHUNT_TOP_N=5
AUTOHUNT_MIN_SCORE=0.6
AUTOHUNT_INITIAL_LOOKBACK_DAYS=7
AUTOHUNT_DIGEST_RETENTION_DAYS=90
AUTOHUNT_SCHEDULE=0 9 * * *

# --- Outreach & Networking ---
OUTREACH_STYLE_GUIDE_PATH=docs/reference/message_To_apprach_recruiters.md
OUTREACH_FOLLOWUP_CADENCE_DAYS=7
OUTREACH_MAX_CHARS=500
OUTREACH_FOLLOWUP_SCHEDULE=0 10 * * *
# SMTP for sending outreach email (POST /outreach/send). Leave SMTP_HOST and
# OUTREACH_FROM_EMAIL blank to disable sending (endpoint returns 503).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
OUTREACH_FROM_EMAIL=

# --- Scheduler (Autopilot Phase 1) ---
# Self-drive the recurring pipeline in-process. Set true on EXACTLY ONE process.
SCHEDULER_ENABLED=false
# Days of scheduler run-history to retain (older rows pruned inline).
SCHEDULER_RUN_RETENTION_DAYS=30

# --- Notifications (Autopilot Phase 2) ---
# Recipient for scheduler digest + job-failure emails. Blank disables. Reuses SMTP_* above.
NOTIFICATION_EMAIL=
# From address for notification email (falls back to SMTP_USERNAME when blank).
NOTIFICATION_FROM_EMAIL=

# === Portfolio (external proof-of-work sources) ===
# Comma-separated source adapters. Empty disables the portfolio module.
PORTFOLIO_SOURCES=
# Supabase PostgREST base URL + public anon key for the "supabase" source.
PORTFOLIO_SUPABASE_URL=
PORTFOLIO_SUPABASE_ANON_KEY=
# GitHub source adapter (optional). For PUBLIC repos, set the username; a token
# is optional and only raises the rate limit (60 -> 5000 req/h).
PORTFOLIO_GITHUB_USERNAME=
PORTFOLIO_GITHUB_TOKEN=
PORTFOLIO_GITHUB_API_URL=https://api.github.com
PORTFOLIO_GITHUB_MAX_REPOS=30
# Set true to include PRIVATE repos: reads the token owner's repos via
# /user/repos. Requires PORTFOLIO_GITHUB_TOKEN with the `repo` scope; the
# username above is then ignored. Keep false for public-only.
PORTFOLIO_GITHUB_INCLUDE_PRIVATE=false
# Char cap for the profile-enrichment text block.
PORTFOLIO_PROFILE_CHAR_CAP=1200
# Default page size for the paginated /portfolio/projects endpoint.
PORTFOLIO_PROJECTS_PAGE_SIZE=12
# Public portfolio site linked from generated artifacts (empty disables the link).
PORTFOLIO_PUBLIC_URL=
# Tracked-link slug prefix: ?ref=<prefix>-<application_id>
PORTFOLIO_REF_PREFIX=hiresense
# Relevant projects cited per generated artifact.
PORTFOLIO_RELEVANT_PROJECTS_TOP_N=2
# Supabase service_role key for reading visitor analytics (Dashboard → Settings → API).
# This key bypasses RLS and is required because visitor_session SELECT is restricted
# to authenticated/service-role only (anon key cannot read it). Empty disables
# the engagement readback entirely — the /portfolio/engagement endpoint returns
# {"configured": false, "visits": []} when unset.
PORTFOLIO_ANALYTICS_READ_KEY=

# --- Inbox scanning (Autopilot Phase 3) ---
# IMAP inbox for recruiter-email detection. Blank IMAP_HOST disables scanning.
# Use an app-specific password.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
# Cron cadence for the inbox_scan scheduler job.
INBOX_SCAN_SCHEDULE=0 */2 * * *
# Min classifier confidence for a signal to get a one-click-appliable status.
INBOX_SIGNAL_MATCH_MIN_CONFIDENCE=0.5

# --- Observability (OpenTelemetry) ---
# Master switch for the telemetry stack.
OTEL_ENABLED=true
# Service name shown in Grafana/Tempo.
OTEL_SERVICE_NAME=hiresense-backend
# OTLP endpoint. Leave EMPTY for console/terminal fallback (no collector).
# Host-run dev with the LGTM stack up: http://localhost:4317. The docker-compose
# app service overrides this to http://otel-lgtm:4317 automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Environment label resource attribute.
DEPLOYMENT_ENVIRONMENT=development
# Root log level (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO
# Log output format: json (structured) or console (human-readable).
LOG_FORMAT=json
# Trace sampling ratio 0.0-1.0.
OTEL_TRACES_SAMPLER_RATIO=1.0
# Use an insecure (plaintext, no-TLS) OTLP gRPC connection. true for the local
# LGTM stack / docker-compose; set false to use TLS.
OTEL_EXPORTER_INSECURE=true
