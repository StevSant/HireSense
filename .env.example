# Docker Compose environment variables
# Copy this file to `.env` (repo root, gitignored) — Docker Compose reads it for
# ${VAR} interpolation in docker-compose.yml. This is separate from backend/.env
# (which is loaded into the app container via env_file).
APP_PORT=8000
FRONTEND_PORT=4200

# --- Database credentials (compose) ---
# POSTGRES_PASSWORD is REQUIRED: docker-compose.yml uses ${POSTGRES_PASSWORD:?...}
# with no committed default, so `docker compose up` fails loudly until you set a
# real value here. Change it before any non-throwaway deployment.
POSTGRES_USER=hiresense
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hiresense

# Host publish for the db port. Defaults (in compose) to 127.0.0.1:5432 —
# loopback only, reachable by local tooling but not the host's network. Set to
# e.g. 0.0.0.0:5432 only if you genuinely need external access.
DB_HOST_PORT=127.0.0.1:5432
