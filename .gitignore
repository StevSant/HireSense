# CV storage is runtime/personal data — never commit CVs (keep dirs via .gitkeep).
# Covers both the repo-root cvs/ (compile.ps1 authoring dir) and backend/cvs/ (app runtime).
cvs/compiled/
cvs/optimized/
cvs/originals/*
!cvs/originals/.gitkeep
backend/cvs/compiled/
backend/cvs/optimized/
backend/cvs/originals/*
!backend/cvs/originals/.gitkeep

# Docker
docker-compose.override.yml

# Superpowers
.superpowers/

# Alembic
alembic/versions/*.pyc
.worktrees/
